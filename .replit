modules = ["nodejs-20", "python-3.11", "web", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "glibcLocales", "libiconv", "libxcrypt", "postgresql", "rustc"]

[userenv]

[userenv.shared]
SUPABASE_DATABASE_URL = "postgresql://postgres.lkwhbhzasxchknzjptvz:irfannursandie@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
REACT_APP_API_URL = "[https://f44d32ec-cbb6-4534-b018-2fb4a22d248a-00-3u70w0ts44hpu.pike.replit.dev](https://f44d32ec-cbb6-4534-b018-2fb4a22d248a-00-3u70w0ts44hpu.pike.replit.dev)"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "weekly-report-truncation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-tests"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python -m uvicorn backend.server:app --host localhost --port 8000 & cd /home/runner/workspace/frontend && PORT=5000 HOST=0.0.0.0 npx craco start"
waitForPort = 5000

[[workflows.workflow]]
name = "weekly-report-truncation"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && (curl -sf http://localhost:8000/api/auth/login -X POST -H 'Content-Type: application/json' -d '{\"email\":\"admin1@raja.id\",\"password\":\"admin123\"}' > /dev/null 2>&1 || (python -m uvicorn backend.server:app --host localhost --port 8000 &> /tmp/backend_test.log & sleep 8)) && cd backend && REACT_APP_BACKEND_URL=http://localhost:8000 python3 -m pytest tests/test_raja_api.py::TestWeeklyReportTruncation -v"

[[workflows.workflow]]
name = "api-tests"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && (curl -sf http://localhost:8000/api/auth/login -X POST -H 'Content-Type: application/json' -d '{\"email\":\"admin1@raja.id\",\"password\":\"admin123\"}' > /dev/null 2>&1 || (python -m uvicorn backend.server:app --host localhost --port 8000 &> /tmp/backend_test.log & sleep 8)) && cd backend && REACT_APP_BACKEND_URL=http://localhost:8000 python -m pytest tests/ -v"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000
exposeLocalhost = true

[deployment]
deploymentTarget = "autoscale"
run = ["python", "-m", "uvicorn", "backend.server:app", "--host", "0.0.0.0", "--port", "5000"]
build = ["sh", "-c", "./build.sh"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
